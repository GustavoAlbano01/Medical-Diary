<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MedicalDiary.Views.LoginPage"
             Title="LoginPage">
    <VerticalStackLayout Padding="30" Spacing="15">
        <Label
            Text="Agenda Médica"
            FontSize="30"
            HorizontalOptions="Center"/>
        
        <Entry
            x:Name="txtEmail"
            Placeholder="Email"/>

        <Entry
            x:Name="txtSenha"
            Placeholder="Senha"
            IsPassword="True"/>

        <Button
            Text="Entrar"
            Clicked="Entrar_Clicked"/>

        <Label
            x:Name="lblErro"
            TextColor="Red"/>
    </VerticalStackLayout>
</ContentPage>